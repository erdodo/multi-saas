# =============================================================
#  MultiSaaS — Ortam Değişkenleri Şablonu
#  Kopyala → .env olarak kaydet, değerleri doldur.
# =============================================================

# ── Veritabanı ────────────────────────────────────────────────
# Lokal geliştirme (npm run dev):
#   DATABASE_URL="postgresql://postgresql:postgresql@localhost:5432/postgresql"
# Docker Compose (hem dev hem prod):
#   DATABASE_URL="postgresql://postgresql:postgresql@postgres:5432/postgresql"
DATABASE_URL="postgresql://kullanici:sifre@host:5432/dbadi"

# ── NextAuth ──────────────────────────────────────────────────
# Rastgele güvenli değer üret: openssl rand -base64 32
NEXTAUTH_SECRET="BURAYA_GUCLU_BIR_SECRET_GIRINIZ"

# Uygulamanın çalıştığı tam URL (sonda / olmadan)
# Lokal: http://localhost:3000
# Pi   : https://saas.erdoganyesil.org
NEXTAUTH_URL="http://localhost:3000"

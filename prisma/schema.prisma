generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                    String                 @id @default(uuid())
  name                  String
  slug                  String?                @unique
  domain                String?                @unique
  setupCompleted        Boolean                @default(false)
  isActive              Boolean                @default(true)
  timezone              String                 @default("Europe/Istanbul")
  phone                 String?
  address               String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  siteTitle             String?
  logoUrl               String?
  faviconUrl            String?
  primaryColor          String?                @default("#3b82f6")
  secondaryColor        String?                @default("#6366f1")
  accentColor           String?                @default("#10b981")
  textOnPrimary         String?                @default("#ffffff")
  fontFamily            String?                @default("inter")
  borderRadius          String?                @default("md")
  darkMode              Boolean                @default(false)
  appointments          Appointment[]
  auditLogs             AuditLog[]
  availabilityRules     AvailabilityRule[]
  cancelPolicies        CancelPolicy?
  customers             Customer[]
  holidays              Holiday[]
  leases                Lease[]
  leasePayments         LeasePayment[]
  locations             Location[]
  notificationLogs      NotificationLog[]
  properties            Property[]
  propertyDocuments     PropertyDocument[]
  propertyOwners        PropertyOwner[]
  propertySubscriptions PropertySubscription[]
  propertyTenants       PropertyTenant[]
  services              Service[]
  staffs                Staff[]
  staffBreaks           StaffBreak[]
  tenantModules         TenantModule[]
  settings              TenantSettings?
  timeOffs              TimeOff[]
  users                 User[]

  @@index([slug])
}

model Module {
  id            String         @id @default(uuid())
  name          String
  key           String         @unique
  description   String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenantModules TenantModule[]
}

model TenantModule {
  id        String   @id @default(uuid())
  tenantId  String
  moduleId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  password        String
  role            String         @default("USER")
  tenantId        String
  isActive        Boolean        @default(true)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Customer {
  id           String        @id @default(uuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  notes        String?
  blacklisted  Boolean       @default(false)
  tenantId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Location {
  id           String        @id @default(uuid())
  tenantId     String
  name         String
  address      String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffs       Staff[]

  @@index([tenantId])
}

model Service {
  id            String         @id @default(uuid())
  tenantId      String
  name          String
  description   String?
  duration      Int
  bufferTime    Int            @default(0)
  price         Float
  currency      String         @default("TRY")
  color         String?        @default("#3b82f6")
  isActive      Boolean        @default(true)
  maxCapacity   Int            @default(1)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appointments  Appointment[]
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffServices StaffService[]

  @@index([tenantId])
}

model Staff {
  id                String             @id @default(uuid())
  tenantId          String
  userId            String?
  name              String
  bio               String?
  avatarUrl         String?
  color             String             @default("#3b82f6")
  isActive          Boolean            @default(true)
  locationId        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  appointments      Appointment[]
  availability      Availability[]
  availabilityRules AvailabilityRule[]
  location          Location?          @relation(fields: [locationId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffBreaks       StaffBreak[]
  staffServices     StaffService[]
  timeOffs          TimeOff[]

  @@index([tenantId])
}

model StaffService {
  staffId   String
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
}

model Availability {
  id        String @id @default(uuid())
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  staff     Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model AvailabilityRule {
  id        String  @id @default(uuid())
  tenantId  String
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@index([staffId])
}

model TimeOff {
  id        String   @id @default(uuid())
  tenantId  String
  staffId   String
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([staffId, startAt, endAt])
}

model StaffBreak {
  id        String  @id @default(uuid())
  staffId   String
  tenantId  String
  dayOfWeek Int
  startTime String
  endTime   String
  label     String?
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([tenantId])
}

model Holiday {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  date      DateTime
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId])
}

model Appointment {
  id            String            @id @default(uuid())
  tenantId      String
  staffId       String
  serviceId     String
  customerId    String?
  locationId    String?
  guestName     String?
  guestPhone    String?
  guestEmail    String?
  customerName  String?
  customerPhone String?
  customerEmail String?
  startAt       DateTime?
  endAt         DateTime?
  startTime     DateTime?
  endTime       DateTime?
  status        String            @default("PENDING")
  notes         String?
  internalNotes String?
  cancelReason  String?
  noShowAt      DateTime?
  confirmedAt   DateTime?
  cancelledAt   DateTime?
  reminderSent  Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  customer      Customer?         @relation(fields: [customerId], references: [id])
  location      Location?         @relation(fields: [locationId], references: [id])
  service       Service           @relation(fields: [serviceId], references: [id])
  staff         Staff             @relation(fields: [staffId], references: [id])
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notifications NotificationLog[]

  @@index([tenantId])
  @@index([staffId, startAt])
  @@index([customerId])
  @@index([status])
}

model CancelPolicy {
  id                       String   @id @default(uuid())
  tenantId                 String   @unique
  minHoursBeforeCancel     Int      @default(12)
  minHoursBeforeReschedule Int      @default(4)
  allowGuestCancel         Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  tenant                   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model NotificationLog {
  id            String       @id @default(uuid())
  tenantId      String
  appointmentId String?
  channel       String
  recipient     String
  subject       String?
  body          String
  status        String       @default("PENDING")
  errorMessage  String?
  retryCount    Int          @default(0)
  sentAt        DateTime?
  createdAt     DateTime     @default(now())
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([appointmentId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String
  oldValue   String?
  newValue   String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
}

model TenantSettings {
  id                    String   @id @default(uuid())
  tenantId              String   @unique
  bookingWindowDays     Int      @default(60)
  minNoticeHours        Int      @default(2)
  maxAppointmentsPerDay Int      @default(0)
  slotIntervalMinutes   Int      @default(15)
  autoConfirm           Boolean  @default(false)
  emailNotifications    Boolean  @default(true)
  smsNotifications      Boolean  @default(false)
  reminderHoursBefore   Int      @default(24)
  primaryColor          String   @default("#3b82f6")
  businessHoursStart    String   @default("09:00")
  businessHoursEnd      String   @default("18:00")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Property {
  id               String                 @id @default(uuid())
  tenantId         String
  ownerId          String?
  title            String
  type             String                 @default("APARTMENT")
  status           String                 @default("AVAILABLE")
  city             String?
  district         String?
  neighborhood     String?
  address          String?
  postalCode       String?
  latitude         Float?
  longitude        Float?
  squareMeters     Float?
  roomCount        String?
  floorNumber      Int?
  totalFloors      Int?
  hasElevator      Boolean                @default(false)
  isFurnished      Boolean                @default(false)
  hasParking       Boolean                @default(false)
  hasBalcony       Boolean                @default(false)
  buildingAge      Int?
  heatingType      String?
  notes            String?
  purchasePrice    Float?
  purchaseCurrency String?                @default("TRY")
  purchaseDate     DateTime?
  marketValue      Float?
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  leases           Lease[]
  owner            PropertyOwner?         @relation(fields: [ownerId], references: [id])
  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents        PropertyDocument[]
  photos           PropertyPhoto[]
  subscriptions    PropertySubscription[]

  @@index([tenantId])
  @@index([status])
  @@index([ownerId])
}

model PropertyOwner {
  id                String     @id @default(uuid())
  tenantId          String
  firstName         String
  lastName          String
  nationalId        String?
  taxNo             String?
  phone             String?
  phone2            String?
  email             String?
  address           String?
  bankName          String?
  iban              String?
  accountHolderName String?
  notes             String?
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  leases            Lease[]
  properties        Property[]
  tenant            Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model PropertyTenant {
  id               String   @id @default(uuid())
  tenantId         String
  firstName        String
  lastName         String
  nationalId       String?
  phone            String?
  phone2           String?
  email            String?
  emergencyContact String?
  emergencyPhone   String?
  notes            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  leases           Lease[]
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Lease {
  id                String             @id @default(uuid())
  tenantId          String
  propertyId        String
  propertyTenantId  String
  ownerId           String?
  startDate         DateTime
  endDate           DateTime
  rentAmount        Float
  currency          String             @default("TRY")
  paymentDayOfMonth Int                @default(1)
  depositAmount     Float              @default(0)
  depositPaid       Boolean            @default(false)
  depositReturnDate DateTime?
  contractUrl       String?
  status            String             @default("ACTIVE")
  terminationReason String?
  autoRenew         Boolean            @default(false)
  renewalRate       Float?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  owner             PropertyOwner?     @relation(fields: [ownerId], references: [id])
  property          Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyTenant    PropertyTenant     @relation(fields: [propertyTenantId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments          LeasePayment[]
  documents         PropertyDocument[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([propertyTenantId])
  @@index([status])
}

model LeasePayment {
  id            String    @id @default(uuid())
  tenantId      String
  leaseId       String
  dueDate       DateTime
  amount        Float
  currency      String    @default("TRY")
  paidAt        DateTime?
  paidAmount    Float?
  paymentMethod String?
  receiptNo     String?
  status        String    @default("PENDING")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lease         Lease     @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([leaseId])
  @@index([status])
  @@index([dueDate])
}

model PropertySubscription {
  id                     String    @id @default(uuid())
  tenantId               String
  propertyId             String
  type                   String
  subscriberName         String?
  subscriberNo           String?
  provider               String?
  contractNo             String?
  estimatedMonthlyAmount Float?
  currency               String    @default("TRY")
  startDate              DateTime?
  endDate                DateTime?
  isActive               Boolean   @default(true)
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  property               Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
}

model PropertyDocument {
  id         String    @id @default(uuid())
  tenantId   String
  propertyId String?
  leaseId    String?
  type       String
  title      String
  fileUrl    String?
  expiresAt  DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lease      Lease?    @relation(fields: [leaseId], references: [id])
  property   Property? @relation(fields: [propertyId], references: [id])
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([leaseId])
}

model PropertyPhoto {
  id         String   @id @default(uuid())
  propertyId String
  url        String
  caption    String?
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}
